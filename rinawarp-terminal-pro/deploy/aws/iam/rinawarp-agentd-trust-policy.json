{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::123456789012:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/REPLACE_OIDC_ID"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "oidc.eks.us-east-1.amazonaws.com/id/REPLACE_OIDC_ID:sub": "system:serviceaccount:rinawarp-system:rinawarp-agentd",
          "oidc.eks.us-east-1.amazonaws.com/id/REPLACE_OIDC_ID:aud": "sts.amazonaws.com"
        }
      }
    }
  ]
}
