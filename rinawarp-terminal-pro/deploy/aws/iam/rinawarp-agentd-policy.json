{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "KmsEnvelopeOps",
      "Effect": "Allow",
      "Action": [
        "kms:GenerateDataKey",
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:us-east-1:123456789012:key/REPLACE_WITH_KMS_KEY_ID"
    },
    {
      "Sid": "AuditBucketObjectLockWrites",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObjectRetention",
        "s3:PutBucketVersioning",
        "s3:PutBucketObjectLockConfiguration",
        "s3:PutBucketLifecycleConfiguration",
        "s3:PutBucketPublicAccessBlock"
      ],
      "Resource": [
        "arn:aws:s3:::rinawarp-audit-archive",
        "arn:aws:s3:::rinawarp-audit-archive/*"
      ]
    }
  ]
}
