{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReplicationToVerifierAccount",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::111111111111:role/rinawarp-attestation-replication"
      },
      "Action": [
        "s3:GetReplicationConfiguration",
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::rinawarp-audit-archive"
    },
    {
      "Sid": "AllowReplicationObjectReads",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::111111111111:role/rinawarp-attestation-replication"
      },
      "Action": [
        "s3:GetObjectVersion",
        "s3:GetObjectVersionTagging",
        "s3:GetObjectVersionAcl"
      ],
      "Resource": "arn:aws:s3:::rinawarp-audit-archive/attestations/*"
    }
  ]
}
