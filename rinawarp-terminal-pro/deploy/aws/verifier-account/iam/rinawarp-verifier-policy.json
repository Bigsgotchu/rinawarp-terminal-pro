{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadReplicatedAttestationObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::rinawarp-attestation-verifier",
        "arn:aws:s3:::rinawarp-attestation-verifier/*"
      ]
    },
    {
      "Sid": "WriteVerifierLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    }
  ]
}
