{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReplicationFromProducerAccount",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::111111111111:role/rinawarp-attestation-replication"
      },
      "Action": [
        "s3:ObjectOwnerOverrideToBucketOwner",
        "s3:ReplicateObject",
        "s3:ReplicateDelete",
        "s3:ReplicateTags"
      ],
      "Resource": "arn:aws:s3:::rinawarp-attestation-verifier/attestations/*"
    },
    {
      "Sid": "AllowVerifierRead",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::222222222222:role/rinawarp-attestation-verifier"
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::rinawarp-attestation-verifier",
        "arn:aws:s3:::rinawarp-attestation-verifier/attestations/*"
      ]
    }
  ]
}
