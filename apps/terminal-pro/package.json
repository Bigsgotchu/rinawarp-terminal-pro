{
  "name": "rinawarp-terminal-pro",
  "private": true,
  "version": "1.0.4",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "RinaWarp Terminal Pro - AI-powered system diagnostic agent",
  "author": "RinaWarp Team <team@rinawarptech.com>",
  "homepage": "https://www.rinawarptech.com",
  "bugs": {
    "url": "https://github.com/rinawarp/terminal-pro/issues"
  },
  "scripts": {
    "clean": "rm -rf dist dist-electron out .vite",
    "build:preload": "node scripts/build-preload.mjs",
    "build:electron": "npm run build:preload && tsc -b tsconfig.json && node scripts/copy-static.mjs",
    "test:prompt-boundary": "npm run build:electron && node --test test/prompt-boundary.test.mjs",
    "test:search-ranking": "npm run build:electron && node --test test/search-ranking.test.mjs",
    "test:plan-risk": "npm run build:electron && node --test test/plan-risk.test.mjs",
    "test:plan-fallback": "npm run build:electron && node --test test/plan-fallback.test.mjs",
    "e2e:smoke": "unset FORCE_COLOR && unset NO_COLOR && unset ELECTRON_RUN_AS_NODE && npm run build:electron && playwright test -c tests/playwright.config.ts",
    "e2e:smoke:headed": "unset FORCE_COLOR && unset NO_COLOR && unset ELECTRON_RUN_AS_NODE && npm run build:electron && playwright test -c tests/playwright.config.ts --headed",
    "dev": "unset ELECTRON_RUN_AS_NODE && npm run build:electron && npx electron .",
    "start": "npx electron .",
    "build": "npm run build:electron",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "build:all": "npm run build:electron && npm run package:linux && npm run package:win",
    "package:linux": "bash ../../deploy/package-linux.sh",
    "package:win": "electron-builder --win --publish never",
    "dist:mac": "npm run build:electron && electron-builder --mac",
    "dist:win": "npm run build:electron && electron-builder --win",
    "dist:linux": "npm run build:electron && electron-builder --linux",
    "dist:all": "npm run build:electron && electron-builder -mwl"
  },
  "dependencies": {
    "@rinawarp/agent": "workspace:*",
    "@rinawarp/core": "workspace:*",
    "@rinawarp/doctor": "workspace:*",
    "@rinawarp/safety": "workspace:*",
    "@rinawarp/tools": "workspace:*",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.36.0",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^56.0.1",
    "playwright": "^1.54.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
