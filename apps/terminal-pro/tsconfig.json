{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "incremental": false,
    "outDir": "./dist-electron",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/smoke-test.ts", "src/**/*-test.ts", "dist", "node_modules"],
  "references": [
    { "path": "../../packages/rinawarp-context" },
    { "path": "../../packages/rinawarp-tools" },
    { "path": "../../packages/rinawarp-safety" },
    { "path": "../../packages/rinawarp-core" },
    { "path": "../../packages/runtime-core" },
    { "path": "../../packages/runtime-contracts" },
    { "path": "../../packages/runtime-platform-electron" },
    { "path": "../../packages/runtime-feature-licensing" },
    { "path": "../../packages/runtime-feature-workspace" },
    { "path": "../../packages/runtime-feature-agentd" },
    { "path": "../../packages/runtime-feature-diagnostics" },
    { "path": "../../packages/runtime-feature-team" },
    { "path": "../../packages/rina-doctor" },
    { "path": "../../packages/rinawarp-agent" }
  ]
}
