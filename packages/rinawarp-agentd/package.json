{
  "name": "@rinawarp/rinawarp-agentd",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "RinaWarp Agent Daemon - manages agent lifecycle, task processing, and health monitoring",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.6.0",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "@rinawarp/rina-runtime": "workspace:*",
    "@rinawarp/context": "workspace:*",
    "@rinawarp/core": "workspace:*",
    "express": "^4.21.0",
    "openai": "^4.0.0",
    "ws": "^8.17.0"
  },
}
