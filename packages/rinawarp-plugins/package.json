{
  "name": "@rinawarp/plugins",
  "version": "1.0.0",
  "description": "Shared terminal plugins for RinaWarp",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./docker": {
      "import": "./dist/dockerPlugin.js",
      "types": "./dist/dockerPlugin.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@rinawarp/core": "workspace:*"
  },
  "keywords": [
    "rinawarp",
    "plugins",
    "terminal",
    "docker"
  ],
  "author": "RinaWarp",
  "license": "MIT"
}
