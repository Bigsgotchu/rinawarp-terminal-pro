{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@rinawarp/rina-core": ["../rina-core/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../rina-core" }
  ]
}
