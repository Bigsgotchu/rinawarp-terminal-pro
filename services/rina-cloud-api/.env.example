NODE_ENV=production
PORT=8787

# Provider config. Keep this server-side only.
OPENAI_API_KEY=sk_live_or_project_key
RINA_OPENAI_MODEL=gpt-4.1-mini

# Stripe billing config.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# Auth and public service config.
RINA_AUTH_SECRET=replace-with-a-long-random-secret
RINA_CLOUD_PUBLIC_BASE_URL=https://api.rinawarptech.com
RINA_ALLOWED_ORIGINS=https://www.rinawarptech.com,app://rinawarp-terminal-pro

# Optional file-backed beta account store.
RINA_CLOUD_ACCOUNT_STORE_FILE=/var/lib/rina-cloud-api/accounts.json

# Optional Stripe return URLs.
STRIPE_CHECKOUT_SUCCESS_URL=https://www.rinawarptech.com/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://www.rinawarptech.com/pricing
STRIPE_PORTAL_RETURN_URL=https://www.rinawarptech.com/account
