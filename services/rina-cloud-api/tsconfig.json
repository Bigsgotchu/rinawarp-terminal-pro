{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@rinawarp/rina-core": ["../../packages/rina-core/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../../packages/rina-core" }]
}
