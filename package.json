{
  "name": "rinawarp-monorepo",
  "version": "1.8.2-beta",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "corepack pnpm --filter rinawarp-terminal-pro dev:e2e",
    "start": "npm run agent:daemon:start && npm run dev:terminal",
    "dev:terminal": "cd apps/terminal-pro && npm run dev",
    "build:vscode-companion": "npm --workspace apps/rinawarp-companion run build",
    "test:companion": "npm --workspace apps/rinawarp-companion run test",
    "test:extensions": "npm run test:companion",
    "package:vscode-companion": "npm --workspace apps/rinawarp-companion run package:vsix",
    "build": "npm --workspace apps/terminal-pro run build:electron",
    "build:desktop": "corepack pnpm --filter rinawarp-terminal-pro build",
    "dist:desktop": "corepack pnpm --filter rinawarp-terminal-pro dist",
    "build:all": "npm run build --workspaces",
    "agent:daemon:start": "npm --workspace packages/rinawarp-agentd run daemon:start",
    "agent:daemon:status": "npm --workspace packages/rinawarp-agentd run daemon:status",
    "agent:daemon:stop": "npm --workspace packages/rinawarp-agentd run daemon:stop",
    "agent:daemon:tasks": "npm --workspace packages/rinawarp-agentd run daemon:task:list",
    "agent:daemon:dlq": "npm --workspace packages/rinawarp-agentd run daemon:task:dlq",
    "clean": "bash scripts/ops/clean-builds.sh",
    "dev:terminal-pro": "cd apps/terminal-pro && npm run dev",
    "pack:terminal": "npm --workspace apps/terminal-pro run build:all",
    "deploy:pages": "bash scripts/deploy/deploy-pages-prod.sh",
    "proof:cloudflare": "bash scripts/deploy/cloudflare-capability-checkpoint.sh",
    "proof:vercel": "bash scripts/deploy/vercel-capability-checkpoint.sh",
    "proof:netlify": "bash scripts/deploy/netlify-capability-checkpoint.sh",
    "proof:docker": "bash scripts/deploy/docker-capability-checkpoint.sh",
    "proof:vps": "bash scripts/deploy/vps-capability-checkpoint.sh",
    "proof:all": "bash scripts/deploy/deploy-capability-proof-all.sh",
    "e2e:smoke": "npm --workspace apps/terminal-pro run e2e:smoke",
    "test:e2e": "corepack pnpm exec playwright test -c apps/terminal-pro/e2e/playwright.config.ts",
    "test:e2e:ui": "corepack pnpm exec playwright test -c apps/terminal-pro/e2e/playwright.config.ts --ui",
    "test:e2e:core": "npm --workspace apps/terminal-pro run test:e2e:core",
    "qa:release-candidate": "npm --workspace apps/terminal-pro run qa:release-candidate",
    "qa:stabilization-core": "npm --workspace apps/terminal-pro run qa:stabilization-core",
    "qa:wiring": "npm --workspace apps/terminal-pro run qa:wiring",
    "qa:intents": "npm --workspace apps/terminal-pro run qa:intents",
    "founder:clean-local": "node scripts/founder/clean-local.mjs",
    "founder:check-repo": "node scripts/founder/check-repo-identity.mjs",
    "guard:no-stubs": "node scripts/guards/check-no-stubs.mjs",
    "guard:no-legacy-contracts": "node scripts/guards/check-no-legacy-contracts.mjs",
    "guard:no-duplicate-rina-spine": "bash scripts/guards/no-duplicate-rina-spine.sh",
    "guard:runtime-integrity": "node scripts/guards/check-no-stubs.mjs",
    "guard:no-fake-success": "node scripts/guards/check-no-fake-success.mjs",
    "guard:feature-reality": "node scripts/guards/check-feature-reality-matrix.mjs",
    "guard:product-constraint-contract": "node scripts/guards/check-product-constraint-contract.mjs",
    "guard:site-account": "node scripts/guards/check-site-account-public-contract.mjs",
    "guard:rina-legacy": "node scripts/guards/check-rina-legacy.mjs",
    "guard:doc-source-of-truth": "node scripts/guards/check-doc-source-of-truth.mjs",
    "report:large-files": "node scripts/guards/report-large-source-files.mjs",
    "guard:intent-contracts": "npm --workspace apps/terminal-pro run qa:intents",
    "guard:single-owner-events": "npm --workspace apps/terminal-pro run qa:ownership",
    "verify:desktop:rc": "bash scripts/qa/verify-desktop-rc.sh",
    "smoke:pages": "SKIP_RELEASE_CONTRACT=1 bash scripts/smoke/prod.sh https://rinawarptech-website.pages.dev",
    "test:lockdown": "bash scripts/guards/guards.sh",
    "verify:site": "node scripts/qa/verify-pages-routes.mjs rinawarptech-website/web",
    "verify:downloads": "node scripts/qa/verify-download-links.mjs",
    "pretest": "npm run test:lockdown && npm run guard:no-stubs && npm run guard:no-legacy-contracts && npm run guard:no-fake-success && npm run guard:product-constraint-contract && npm run guard:site-account && npm run guard:rina-legacy",
    "test": "npm run test:companion && npm --workspace apps/terminal-pro run test:unit && npm --workspace apps/terminal-pro run test:agent && npm --workspace apps/terminal-pro run test:cli",
    "test:safety": "npm --workspace packages/rinawarp-deploy-capabilities run test:safety",
    "test:failure": "npm --workspace packages/rinawarp-deploy-capabilities run test:failure",
    "release:readiness": "npm run test:companion && npm --workspace apps/terminal-pro run release:readiness",
    "smoke:prod": "bash scripts/smoke/prod.sh https://www.rinawarptech.com",
    "smoke:prod:windows-required": "REQUIRE_WINDOWS_PATHS=1 bash scripts/smoke/prod.sh https://www.rinawarptech.com",
    "beta:status": "bash scripts/ops/beta-status.sh",
    "beta:followups": "bash scripts/ops/beta-followups.sh",
    "beta:digest": "bash scripts/ops/beta-digest.sh",
    "beta:issue-drafts": "bash scripts/ops/beta-issue-drafts.sh",
    "beta:outreach:generate": "node scripts/founder/beta-outreach/generate-posts.mjs",
    "beta:outreach:add-lead": "bash scripts/founder/beta-outreach/add-lead.sh",
    "beta:outreach:show-leads": "bash scripts/founder/beta-outreach/show-leads.sh",
    "beta:export-signups": "bash scripts/ops/beta-export-signups.sh",
    "beta:email-welcome": "bash scripts/ops/beta-email-welcome.sh",
    "beta:run": "node scripts/founder/beta-outreach/run-beta.mjs",
    "verify:prelaunch:full": "bash scripts/qa/verify-prelaunch-full.sh",
    "e2e:revenue": "bash scripts/smoke/e2e-revenue.sh https://www.rinawarptech.com https://www.rinawarptech.com https://rinawarp-downloads.rinawarptech.workers.dev",
    "kpi:snapshot": "bash scripts/ops/kpi-snapshot.sh https://www.rinawarptech.com https://www.rinawarptech.com https://rinawarp-downloads.rinawarptech.workers.dev",
    "audit:prod": "bash scripts/audit/site.sh https://www.rinawarptech.com https://rinawarptech-website.pages.dev https://www.rinawarptech.com/releases/SHASUMS256.txt",
    "audit:compare": "bash scripts/audit/compare.sh https://www.rinawarptech.com https://rinawarptech-website.pages.dev",
    "smoke:stripe": "bash scripts/smoke/stripe.sh https://www.rinawarptech.com https://www.rinawarptech.com",
    "audit:stripe-success": "bash scripts/audit/stripe-success.sh",
    "report:revenue-daily": "bash scripts/ops/revenue-daily-report.sh",
    "deploy:add-twilio-dns": "bash scripts/deploy/add-twilio-dns-record.sh",
    "demo:record:fix-project": "npm --workspace apps/terminal-pro run build:electron && bash scripts/ops/record-fix-project-demo.sh",
    "rina:reality-demo": "node apps/terminal-pro/scripts/rina-reality-demo.mjs",
    "founder:gui-check": "echo 'Run the AppImage manually on desktop and verify Rina loop works'",
    "verify:appimage:ci": "bash deploy/verify-appimage-ci.sh",
    "release:desktop": "bash deploy/release-runner.sh",
    "release:bump": "bash deploy/bump-release-version.sh",
    "release:publish:desktop": "bash scripts/release/publish-desktop-release.sh",
    "release:publish:metadata": "bash scripts/release/publish-update-metadata.sh",
    "check:updater": "bash scripts/check-updater.sh",
    "check:updater:upgrade": "node scripts/qa/verify-updater-upgrade-path.mjs",
    "cli:list-agents": "node --import ./apps/terminal-pro/node_modules/tsx/dist/loader.mjs tools/list-agents.ts",
    "cli:install-agent": "node --import ./apps/terminal-pro/node_modules/tsx/dist/loader.mjs tools/install-agent.ts",
    "lint": "npm --workspace apps/terminal-pro run lint",
    "lint:fix": "npm --workspace apps/terminal-pro run lint:fix",
    "format": "prettier --write 'apps/**/*.{ts,tsx,js,cjs,mjs}' 'packages/**/*.{ts,tsx,js,cjs,mjs}' 'tools/**/*.{ts,tsx,js,cjs,mjs}'",
    "format:check": "prettier --check 'apps/**/*.{ts,tsx,js,cjs,mjs}' 'packages/**/*.{ts,tsx,js,cjs,mjs}' 'tools/**/*.{ts,tsx,js,cjs,mjs}'",
    "spellcheck": "cspell 'apps/**/*.{ts,tsx,js,cjs,mjs}' 'packages/**/*.{ts,tsx,js,cjs,mjs}' 'tools/**/*.{ts,tsx,js,cjs,mjs}'"
  },
  "keywords": [
    "rinawarp",
    "agent",
    "ai",
    "terminal",
    "electron"
  ],
  "author": "RinaWarp Team",
  "license": "MIT",
  "resolutions": {
    "typescript": "5.4.2",
    "electron": "35.7.5",
    "playwright": ">=1.55.1"
  },
  "pnpm": {
    "overrides": {
      "electron": "35.7.5",
      "tar": ">=7.5.11",
      "minimatch": ">=10.2.3",
      "yauzl": ">=3.2.1",
      "@tootallnate/once": ">=3.0.1",
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.2",
      "path-to-regexp": ">=0.1.13",
      "picomatch": ">=4.0.4",
      "@xmldom/xmldom": ">=0.8.12"
    },
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  },
  "dependencies": {
    "posthog-node": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "cspell": "^9.7.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.1"
  },
  "packageManager": "pnpm@10.0.0+sha512.b8fef5494bd3fe4cbd4edabd0745df2ee5be3e4b0b8b08fa643aa3e4c6702ccc0f00d68fa8a8c9858a735a0032485a44990ed2810526c875e416f001b17df12b"
}
