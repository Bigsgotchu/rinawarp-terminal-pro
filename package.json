{
  "name": "rinawarp-terminal-pro",
  "version": "0.1.0",
  "description": "A proof-first AI agent workbench for technical work",
  "main": "dist/electron/main.js",
  "author": "RinaWarp",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"yarn dev:renderer\" \"yarn dev:electron\"",
    "dev:renderer": "cd renderer && yarn start",
    "dev:electron": "tsc -p electron/tsconfig.json && electron .",
    "build": "yarn build:renderer && yarn build:electron",
    "build:renderer": "cd renderer && yarn build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package": "electron-builder",
    "postinstall": "cd renderer && yarn install"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "electron-updater": "^6.1.7",
    "mongodb": "^6.3.0",
    "openai": "^6.32.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/uuid": "^11.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.rinawarp.terminal-pro",
    "productName": "RinaWarp Terminal Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/build/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://updates.rinawarp.com"
    }
  }
}
