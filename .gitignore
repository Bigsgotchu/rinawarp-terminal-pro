# Secrets and sensitive files
**/*.secrets
**/.env*
!**/.env.example
**/.wf_secrets
**/wrangler/state/
**/.wrangler/state/
**/.sentry.properties

# Dependency directories
node_modules/
package-lock.json
yarn.lock
website/.pages-dist/
.pnp/
.pnp.js/

# Build outputs (keep dist, only ignore secrets in build dirs)
**/build/
!apps/terminal-pro/build/
!apps/terminal-pro/build/afterSign.cjs
!apps/terminal-pro/build/entitlements.mac.plist
!apps/terminal-pro/build/entitlements.mac.inherit.plist
!scripts/build/
!scripts/build/*.mjs

# Terminal Pro build artifacts
apps/terminal-pro/dist/
apps/terminal-pro/dist-renderer/
apps/terminal-pro/dist-electron/
apps/dist-electron/
services/rina-cloud-api/dist/
apps/terminal-pro/out/
apps/terminal-pro/.vite/
apps/terminal-pro/test-results/
apps/terminal-pro/playwright-report/
apps/terminal-pro/.playwright/
apps/terminal-pro/.cache/

# Agent test artifacts and metrics (should not be committed)
.tmp-agentd-test/
.rinawarp/
.rinawarp/**

# Analytics and runtime data (generated locally)
analytics-funnel.json
analytics-usage.json
analytics-device-id.txt
.rinawarp-test-data/

# Playwright / E2E artifacts (source specs only)
apps/terminal-pro/e2e/videos/
apps/terminal-pro/e2e/screenshots/*
!apps/terminal-pro/e2e/screenshots/.gitkeep

# Wrangler local cache (never commit account metadata)
website/.wrangler/cache/
website/wrangler.toml.bak

# Package-specific build artifacts
packages/*/dist/
packages/*/tsconfig.tsbuildinfo
apps/terminal-pro/tsconfig.tsbuildinfo
packages/*/.turbo/
packages/*/coverage/

# Local editor state
*.code-workspace

# Local builds/artifacts
dist/
dist-renderer/
release-artifacts/
test-results/
.playwright-mcp/
release/*.exe
release/*.AppImage
release/*.deb
release/*.dmg

# Test source files (these SHOULD be committed)
!apps/terminal-pro/src/renderer/rina-agent-core.test.ts
!apps/terminal-pro/tests/e2e/*.test.ts
!apps/terminal-pro/tests/e2e/*.spec.ts
!apps/terminal-pro/e2e/golden/**/*.spec.ts

# Coverage reports
coverage/

# Local downloaded installers
RinaWarp-Terminal-Pro-*.AppImage
*.deb

# Local Netlify folder
.netlify

# Local agent/editor state
.codex
.continue/
.kilocode/
.kilocodemodes
.kilocodeignore
kilo.jsonc
RinaWarp.code-workspace

# Local receipts and caches
runs/
artifacts/release-evidence/
scripts/__pycache__/
apps/terminal-pro/demo-*.png
output/demo-recordings/
output/doc/

# VS Code companion generated artifacts
apps/rinawarp-companion/dist/
apps/rinawarp-companion/*.vsix
apps/rinawarp-companion/tsconfig.tsbuildinfo
backup-*.bundle
