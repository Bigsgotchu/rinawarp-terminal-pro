# Secrets and sensitive files
**/*.secrets
**/.env*
 !**/.env.example
**/.wf_secrets
**/wrangler/state/
**/.wrangler/state/

# Dependency directories
node_modules/
website/.pages-dist/
.pnp/
.pnp.js/

# Build outputs (keep dist, only ignore secrets in build dirs)
**/build/
!apps/terminal-pro/build/
!apps/terminal-pro/build/afterSign.cjs
!apps/terminal-pro/build/entitlements.mac.plist
!apps/terminal-pro/build/entitlements.mac.inherit.plist

# Terminal Pro build artifacts
apps/terminal-pro/dist/
apps/terminal-pro/dist-electron/
apps/terminal-pro/out/
apps/terminal-pro/.vite/
apps/terminal-pro/test-results/
apps/terminal-pro/playwright-report/
apps/terminal-pro/.playwright/
apps/terminal-pro/.cache/

# Agent test artifacts and metrics (should not be committed)
.tmp-agentd-test/
.rinawarp/
.rinawarp/**

# Analytics and runtime data (generated locally)
analytics-funnel.json
analytics-usage.json
analytics-device-id.txt

# Package-specific build artifacts
packages/*/dist/
packages/*/tsconfig.tsbuildinfo
packages/*/.turbo/
packages/*/coverage/

# Release artifacts that shouldn't be in repo
release/*.exe
release/*.AppImage
release/*.deb
release/*.dmg

# Test results
test-results/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
coverage/
RinaWarp-Terminal-Pro-*.AppImage
*.deb

# Local Netlify folder
.netlify

# Local agent/editor state
.codex
.kilocode/
.kilocodeignore
RinaWarp.code-workspace

# Local receipts and caches
runs/
scripts/__pycache__/

# VS Code companion generated artifacts
apps/rinawarp-companion/dist/
apps/rinawarp-companion/*.vsix
apps/rinawarp-companion/tsconfig.tsbuildinfo
